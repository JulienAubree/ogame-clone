# Database
DATABASE_URL=postgresql://exilium:exilium@localhost:5432/exilium

# Redis
REDIS_URL=redis://localhost:6379

# Auth — CHANGE IN PRODUCTION (use a random 32+ char string)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_IN=7d

# Server
API_PORT=3000
NODE_ENV=development

# Assets — path to the assets directory (REQUIRED in production)
ASSETS_DIR=/opt/exilium/uploads/assets

# Push Notifications — generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:admin@exilium.app
