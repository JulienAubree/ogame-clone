# Database
DATABASE_URL=postgresql://ogame:ogame@localhost:5432/ogame

# Redis
REDIS_URL=redis://localhost:6379

# Auth — CHANGE IN PRODUCTION (use a random 32+ char string)
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_IN=7d

# Server
API_PORT=3000
NODE_ENV=development

# Assets — path to the assets directory (prod: /opt/ogame-clone/uploads/assets)
# ASSETS_DIR=/opt/ogame-clone/uploads/assets
