exilium-game.com, www.exilium-game.com {
	@game_assets path /assets/buildings/* /assets/research/* /assets/ships/* /assets/defenses/* /assets/planets/* /assets/planets/*/* /assets/flagships/*
	handle @game_assets {
		root * /opt/exilium/uploads
		file_server
	}

	handle /trpc/* {
		reverse_proxy localhost:3000
	}

	handle /sse {
		reverse_proxy localhost:3000 {
			flush_interval -1
		}
	}

	handle /health {
		reverse_proxy localhost:3000
	}

	handle {
		root * /opt/exilium/apps/web/dist
		try_files {path} /index.html
		file_server
	}
}

admin.exilium-game.com {
	handle /trpc/* {
		reverse_proxy localhost:3000
	}

	handle /admin/* {
		reverse_proxy localhost:3000
	}

	@game_assets path /assets/buildings/* /assets/research/* /assets/ships/* /assets/defenses/* /assets/planets/* /assets/planets/*/* /assets/flagships/*
	handle @game_assets {
		root * /opt/exilium/uploads
		file_server
	}

	handle {
		root * /opt/exilium/apps/admin/dist
		try_files {path} /index.html
		file_server
	}
}
