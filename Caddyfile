# Shared security headers snippet. Applied to all hosts. The app has no
# third-party scripts, no eval, and no inline <script> tags (Vite emits all
# scripts as external modules), so 'self' is sufficient for script-src.
# React injects style attributes at runtime, so style-src needs 'unsafe-inline'
# — acceptable since inline CSS carries far less risk than inline JS.
(security_headers) {
	header {
		Content-Security-Policy "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self' data:; connect-src 'self'; worker-src 'self' blob:; manifest-src 'self'; object-src 'none'; base-uri 'self'; frame-ancestors 'none'; form-action 'self'; upgrade-insecure-requests"
		X-Content-Type-Options nosniff
		X-Frame-Options DENY
		Referrer-Policy strict-origin-when-cross-origin
		Permissions-Policy "geolocation=(), microphone=(), camera=(), payment=()"
		-Server
	}
}

# Basic auth snippet loaded from an out-of-repo file so the bcrypt hash never
# lands in git. The file is created during setup from /etc/caddy/caddy.env
# and defines `(basic_gate)`. Applied only to the static SPA handler — NOT to
# /trpc/*: when the API returns its own 401 (e.g. app-level JWT missing), Caddy
# basicauth attaches WWW-Authenticate: Basic to that response, which would
# trick the browser into re-prompting for basic auth on every tRPC call.
import /etc/caddy/basic-auth.conf

exilium-game.com, www.exilium-game.com {
	import security_headers

	@game_assets path /assets/buildings/* /assets/buildings/*/* /assets/research/* /assets/ships/* /assets/defenses/* /assets/defenses/*/* /assets/planets/* /assets/planets/*/* /assets/flagships/* /assets/avatars/*
	handle @game_assets {
		root * /opt/exilium/uploads
		file_server
	}

	handle /trpc/* {
		reverse_proxy localhost:3000
	}

	handle /sse {
		reverse_proxy localhost:3000 {
			flush_interval -1
		}
	}

	handle /health {
		reverse_proxy localhost:3000
	}

	handle {
		root * /opt/exilium/apps/web/dist
		try_files {path} /index.html
		file_server
	}
}

admin.exilium-game.com {
	import security_headers

	# API routes are NOT behind basic auth: adminProcedure JWT check + the
	# global rate-limit (300 req/min/IP) protect them. Attaching basicauth
	# here would make the browser re-prompt on every 401 from the app layer.
	handle /trpc/* {
		reverse_proxy localhost:3000
	}

	handle /admin/* {
		reverse_proxy localhost:3000
	}

	@game_assets path /assets/buildings/* /assets/buildings/*/* /assets/research/* /assets/ships/* /assets/defenses/* /assets/defenses/*/* /assets/planets/* /assets/planets/*/* /assets/flagships/* /assets/avatars/*
	handle @game_assets {
		root * /opt/exilium/uploads
		file_server
	}

	# Static SPA is gated by basic auth so crawlers can't index the login page
	# and randos can't probe the admin UI.
	handle {
		import basic_gate
		root * /opt/exilium/apps/admin/dist
		try_files {path} /index.html
		file_server
	}
}

# Staging mirrors the prod routing but points at the separate API (port 3001),
# separate code checkout, and separate assets dir.
staging.exilium-game.com {
	import security_headers

	handle /trpc/* {
		reverse_proxy localhost:3001
	}

	handle /sse {
		reverse_proxy localhost:3001 {
			flush_interval -1
		}
	}

	handle /health {
		reverse_proxy localhost:3001
	}

	@game_assets path /assets/buildings/* /assets/buildings/*/* /assets/research/* /assets/ships/* /assets/defenses/* /assets/defenses/*/* /assets/planets/* /assets/planets/*/* /assets/flagships/* /assets/avatars/*
	handle @game_assets {
		root * /opt/exilium-staging/uploads
		file_server
	}

	handle {
		import basic_gate
		root * /opt/exilium-staging/apps/web/dist
		try_files {path} /index.html
		file_server
	}
}

admin-staging.exilium-game.com {
	import security_headers

	handle /trpc/* {
		reverse_proxy localhost:3001
	}

	handle /admin/* {
		reverse_proxy localhost:3001
	}

	@game_assets path /assets/buildings/* /assets/buildings/*/* /assets/research/* /assets/ships/* /assets/defenses/* /assets/defenses/*/* /assets/planets/* /assets/planets/*/* /assets/flagships/* /assets/avatars/*
	handle @game_assets {
		root * /opt/exilium-staging/uploads
		file_server
	}

	handle {
		import basic_gate
		root * /opt/exilium-staging/apps/admin/dist
		try_files {path} /index.html
		file_server
	}
}
