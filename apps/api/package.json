    "@exilium/shared": "workspace:*",
    "@fastify/cors": "^10.0.2",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@trpc/server": "^11.0.0-rc.682",
    "argon2": "^0.41.1",
    "bullmq": "^5.71.0",
    "drizzle-orm": "^0.38.3",
    "fastify": "^5.2.1",
    "ioredis": "^5.4.2",
    "jose": "^6.0.8",
    "postgres": "^3.4.5",
    "resend": "^6.12.0",
    "sharp": "^0.34.5",
    "web-push": "^3.6.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/busboy": "^1.5.4",
    "@types/node": "^22.10.7",
    "@types/web-push": "^3.6.4",
    "tsx": "^4.19.2",
