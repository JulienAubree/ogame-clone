{
  "name": "@exilium/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    "./trpc": {
      "import": "./src/trpc/app-router.ts",
      "types": "./src/trpc/app-router.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "worker": "tsx watch src/workers/worker.ts",
    "worker:start": "node dist/workers/worker.js",
    "build": "tsc",
    "start": "node dist/index.js",
